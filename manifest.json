{
    "manifest_version": 3,
    "name": "Voice Clipboard",
    "version": "7.0.0",
    "description": "Click any text field, speak, and your words appear instantly.",
    "content_scripts": [
        {
            "matches": [
                "https://*/*"
            ],
            "js": [
                "src/config.js",
                "src/dom-utils.js",
                "src/ui.js",
                "src/recognizer.js",
                "src/main.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": [
                "permission.html",
                "permission.js"
            ],
            "matches": [
                "https://*/*"
            ]
        }
    ],
    "icons": {
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
